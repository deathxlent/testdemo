{
  "manifest_version": 3,
  "name": "图片像素化工具",
  "version": "1.0.0",
  "description": "将图片转换为像素画和拼豆画",
  "permissions": [
    "contextMenus",
    "storage",
    "scripting",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "图片像素化工具"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
